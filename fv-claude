#!/bin/bash
# Fallback Vision — 一键启动 Claude Code
FV_PORT=${FALLBACK_VISION_PORT:-8789}
FV_DIR="$(cd "$(dirname "$0")" && pwd)"
FV_RESTART_FLAG="$HOME/.fallback-vision/.restart"

mkdir -p "$HOME/.fallback-vision"
rm -f "$FV_RESTART_FLAG"

echo "⚡ Fallback Vision — Claude Code 模式"
echo ""

# 自动安装依赖（仅首次）
if [ ! -d "$FV_DIR/node_modules" ]; then
  echo "📦 首次运行，正在安装依赖..."
  cd "$FV_DIR" && npm install --omit=dev 2>&1 | tail -3
  echo ""
fi

# 启动服务
if curl -s "http://127.0.0.1:${FV_PORT}/healthz" > /dev/null 2>&1; then
  echo "✅ 服务已在运行"
else
  echo "🚀 启动服务..."
  cd "$FV_DIR" && npx fallback-vision --port "$FV_PORT" &
  sleep 2
  if curl -s "http://127.0.0.1:${FV_PORT}/healthz" > /dev/null 2>&1; then
    echo "✅ 服务启动成功"
  else
    echo "❌ 启动失败，请检查端口 ${FV_PORT}"
    exit 1
  fi
fi

echo "🌐 配置页面: http://127.0.0.1:${FV_PORT}/"
command -v open &>/dev/null && open "http://127.0.0.1:${FV_PORT}/"
command -v xdg-open &>/dev/null && xdg-open "http://127.0.0.1:${FV_PORT}/"

echo ""
echo "📋 在网页上配置好后，点击「保存并重启使用」"
echo ""

while true; do
  if [ -f "$FV_RESTART_FLAG" ]; then
    rm -f "$FV_RESTART_FLAG"
    echo "🔄 正在重启..."
    pkill -f "fallback-vision" 2>/dev/null
    sleep 1
    break
  fi
  curl -s "http://127.0.0.1:${FV_PORT}/healthz" > /dev/null 2>&1 || break
  sleep 1
done

echo "🚀 重新启动服务..."
cd "$FV_DIR" && npx fallback-vision --port "$FV_PORT" &
sleep 2

if curl -s "http://127.0.0.1:${FV_PORT}/healthz" > /dev/null 2>&1; then
  echo "✅ 服务重启成功"
  echo "🤖 启动 Claude Code..."
  ANTHROPIC_BASE_URL="http://127.0.0.1:${FV_PORT}" exec claude
else
  echo "❌ 重启失败"
  exit 1
fi
