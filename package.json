{
  "name": "fallback-vision",
  "version": "0.6.2",
  "description": "AI Gateway with visual fallback routing, hybrid multi-backend search, and protocol translation for Claude Code & Codex",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fallback-vision": "dist/cli.js",
    "fallback-vision-setup": "dist/setup.js",
    "fv-claude": "bin/fv-claude.js",
    "fv-codex": "bin/fv-codex.js",
    "fv-claude-docker": "bin/fv-claude.js",
    "fv-codex-docker": "bin/fv-codex.js",
    "fv-stop": "bin/fv-stop.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "setup": "tsx src/setup.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai-gateway",
    "visual-fallback",
    "routing",
    "proxy",
    "claude-code",
    "codex",
    "mimo",
    "deepseek",
    "multi-model",
    "vision-model",
    "protocol-translation",
    "hybrid-search",
    "web-search",
    "openai-compatible",
    "anthropic-compatible"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin",
    "docs",
    "CHANGELOG.md",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "AGENTS.md"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "undici": "^8.3.0"
  }
}
