{
  "name": "fallback-vision",
  "version": "0.5.0",
  "description": "AI Gateway with intelligent visual fallback routing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fallback-vision": "dist/cli.js",
    "fallback-vision-setup": "dist/setup.js",
    "fv-claude": "bin/fv-claude.js",
    "fv-codex": "bin/fv-codex.js",
    "fv-claude-docker": "bin/fv-claude.js",
    "fv-codex-docker": "bin/fv-codex.js",
    "fv-stop": "bin/fv-stop.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "setup": "tsx src/setup.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai-gateway",
    "visual-fallback",
    "routing",
    "proxy",
    "claude-code",
    "codex"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin",
    "Dockerfile",
    "docker-compose.yml",
    "README.md"
  ],
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}