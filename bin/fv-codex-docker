#!/bin/bash
# Fallback Vision — Docker 一键启动 Codex
# 安装后全局可用: fv-codex-docker

FV_PORT=${FALLBACK_VISION_PORT:-8789}
FV_IMAGE="yvesnihaohaode/fallback-vision:latest"
FV_CONTAINER="fallback-vision"

echo "⚡ Fallback Vision — Docker + Codex 模式"
echo ""

if ! command -v docker &> /dev/null; then
  echo "❌ 未安装 Docker"
  echo "请先安装: https://docs.docker.com/get-docker/"
  exit 1
fi

if ! docker image inspect "$FV_IMAGE" &> /dev/null; then
  echo "📦 拉取镜像: $FV_IMAGE"
  docker pull "$FV_IMAGE"
fi

if docker ps -a --format '{{.Names}}' | grep -q "^${FV_CONTAINER}$"; then
  echo "🗑️  停止旧容器..."
  docker stop "$FV_CONTAINER" 2>/dev/null
  docker rm "$FV_CONTAINER" 2>/dev/null
fi

echo "🚀 启动容器..."
docker run -d \
  --name "$FV_CONTAINER" \
  -p "$FV_PORT:8789" \
  -e FALLBACK_VISION_PORT=8789 \
  -v "$HOME/.fallback-vision:/root/.fallback-vision" \
  "$FV_IMAGE"

sleep 2

if curl -s "http://127.0.0.1:${FV_PORT}/healthz" > /dev/null 2>&1; then
  echo "✅ 容器启动成功"
else
  echo "❌ 启动失败，查看日志:"
  docker logs "$FV_CONTAINER"
  exit 1
fi

echo "🌐 配置页面: http://127.0.0.1:${FV_PORT}/"
command -v open &>/dev/null && open "http://127.0.0.1:${FV_PORT}/"
command -v xdg-open &>/dev/null && xdg-open "http://127.0.0.1:${FV_PORT}/"

echo ""
echo "📋 在网页上配置好后，点击「保存并重启使用」"
echo ""

FV_RESTART_FLAG="$HOME/.fallback-vision/.restart"
mkdir -p "$HOME/.fallback-vision"
rm -f "$FV_RESTART_FLAG"

while true; do
  if [ -f "$FV_RESTART_FLAG" ]; then
    rm -f "$FV_RESTART_FLAG"
    echo "🔄 正在重启容器..."
    docker restart "$FV_CONTAINER"
    sleep 2
    break
  fi
  if ! docker ps --format '{{.Names}}' | grep -q "^${FV_CONTAINER}$"; then
    echo "⚠️  容器已停止"
    exit 1
  fi
  sleep 1
done

if curl -s "http://127.0.0.1:${FV_PORT}/healthz" > /dev/null 2>&1; then
  echo "✅ 容器重启成功"
  echo "🔧 启动 Codex..."
  if [ -d "/Applications/Codex.app" ]; then
    open /Applications/Codex.app
  else
    exec codex
  fi
else
  echo "❌ 重启失败"
  exit 1
fi
