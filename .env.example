# fallback-vision — Environment Configuration
# Copy this file to .env and fill in your API keys.

# MiMo (Xiaomi)
# MIMO_API_KEY=sk-xxxxxxxxxxxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Server
# FALLBACK_VISION_PORT=8789
# FALLBACK_VISION_HOST=127.0.0.1
# FALLBACK_VISION_VERBOSE=1
# FALLBACK_VISION_STRATEGY=balanced
